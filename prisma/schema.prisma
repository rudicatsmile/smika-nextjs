generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  SUPER_ADMIN
  HR
  PIMPINAN
  PEMILIK_YAYASAN_1
  PEMILIK_YAYASAN_2
  PEGAWAI
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum MaritalStatus {
  BELUM_MENIKAH
  MENIKAH
  CERAI_HIDUP
  CERAI_MATI
}

enum EmploymentStatus {
  AKTIF
  NON_AKTIF
  CUTI
  PENSIUN
}

enum PositionType {
  SEKOLAH
  YAYASAN
}

enum DepartmentType {
  SEKOLAH
  YAYASAN
  SEKURITI
  MAINTENANCE
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique
  nip          String?   @unique
  passwordHash String
  role         Role      @default(PEGAWAI)
  isActive     Boolean   @default(true)
  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  passwordResetTokens PasswordResetToken[]
  activityLogs        ActivityLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PositionDepartment {
  id           String     @id @default(cuid())
  positionId   String
  departmentId String
  position     Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([positionId, departmentId])
}

model Department {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  description   String?
  departmentType DepartmentType   @default(SEKOLAH)
  canTeach      Boolean            @default(false)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  employees     Employee[]
  positions     PositionDepartment[]
}

model Position {
  id            String             @id @default(cuid())
  name          String             @unique
  description   String?
  positionType  PositionType       @default(SEKOLAH)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  employees     Employee[]
  departments   PositionDepartment[]
}

model EmploymentStatusMaster {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  employees Employee[]
}

model Religion {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  employees Employee[]
}

model BloodType {
  id        String     @id @default(cuid())
  name      String     @unique
  isActive  Boolean    @default(true)
  employees Employee[]
}

model Education {
  id               String             @id @default(cuid())
  name             String             @unique
  level            String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  educationHistories EducationHistory[]
  children         Child[]
  spouses          Spouse[]
}

model Subject {
  id        String     @id @default(cuid())
  name      String     @unique
  urutan    Int
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model EducationHistory {
  id             String     @id @default(cuid())
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  educationId     String
  education      Education @relation(fields: [educationId], references: [id])
  institutionName String?
  major          String?
  graduationYear Int?
  startDate      DateTime?
  endDate        DateTime?
  gpa            Float?
  isGraduated    Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Occupation {
  id        String     @id @default(cuid())
  name      String     @unique
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  children  Child[]
  spouses   Spouse[]
}

model Year {
  id                 String             @id @default(cuid())
  name               String             @unique
  order              Int                @default(0)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  dp3                DP3[]
  appConfiguration   AppConfiguration[]
}

model StatusDP3 {
  id        String     @id @default(cuid())
  name      String     @unique
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  dp3       DP3[]
}

model Child {
  id             String     @id @default(cuid())
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name           String
  placeOfBirth   String?
  dateOfBirth    DateTime?
  gender         Gender?
  relationship   String?
  educationId    String?
  education      Education? @relation(fields: [educationId], references: [id])
  occupationId   String?
  occupation     Occupation? @relation(fields: [occupationId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Spouse {
  id             String     @id @default(cuid())
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name           String
  placeOfBirth   String?
  dateOfBirth    DateTime?
  gender         Gender?
  relationship   String?
  educationId    String?
  education      Education? @relation(fields: [educationId], references: [id])
  occupationId   String?
  occupation     Occupation? @relation(fields: [occupationId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Training {
  id                String     @id @default(cuid())
  employeeId        String
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name              String
  type              String
  organizerLocation String?
  batch             String?
  date              DateTime?
  certificateNumber String?
  certificateDate   DateTime?
  certificateFile   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model EmploymentDocument {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  letterName  String
  date        DateTime?
  number      String?
  description String?
  file        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Certification {
  id                        String     @id @default(cuid())
  employeeId                String
  employee                  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  isCertifiedTeacher        Boolean
  certificationBaseSchool   String?
  educationCertificateNumber String?
  certificationYear        Int?
  inpassingBaseSchool      String?
  inpassingSkNumber        String?
  inpassingSkYear          Int?
  file                     String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model WorkUnit {
  id                   String     @id @default(cuid())
  employeeId           String
  employee             Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  worksElsewhere       Boolean
  workplaceName        String?
  status               String?
  position             String?
  positionFunction     String?
  workplaceAddress     String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model HealthData {
  id                    String     @id @default(cuid())
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  healthcareProviderName String?
  level1HealthFacility   String?
  bpjsNumber            String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model SocialOrganization {
  id               String     @id @default(cuid())
  employeeId       String
  employee         Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organizationName String?
  organizationAddress String?
  position         String?
  joinDate         DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ImportantDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType String // KTP, KARTU_KELUARGA, IJAZAH, NPWP, BPJS, SERTIFIKASI_PENDIDIKAN, SK_PENGANGKATAN
  fileUrl    String?
  uploadedAt DateTime @default(now())
  updatedAt  DateTime   @updatedAt
}

model Kesediaan {
  id                  String   @id @default(cuid())
  employeeId          String
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tanggal             DateTime
  isBersedia          Boolean
  alasanKesanggupan   String?
  kesediaanHariKerja  String?
  photo               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DP3 {
  id                                 String   @id @default(cuid())
  employeeId                         String
  employee                           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tahunId                            String
  tahun                              Year     @relation(fields: [tahunId], references: [id])
  statusDP3Id                        String
  statusDP3                          StatusDP3 @relation(fields: [statusDP3Id], references: [id])
  kualitasKerjaNilai                 Int
  kualitasKerjaAlasan                String?
  kehadiranDanKedisiplinanNilai      Int
  kehadiranDanKedisiplinanAlasan     String?
  kerjasamaTimNilai                  Int
  kerjasamaTimAlasan                 String?
  komitmenVisiMisiNilai              Int
  komitmenVisiMisiAlasan             String?
  pengembanganDiriNilai              Int
  pengembanganDiriAlasan             String?
  penggunaanTeknologiNilai           Int
  penggunaanTeknologiAlasan          String?
  ketaatanKepatuhanNilai             Int
  ketaatanKepatuhanAlasan            String?
  komunikasiEfektifNilai             Int
  komunikasiEfektifAlasan            String?
  inisiatifProblemSolvingNilai      Int
  inisiatifProblemSolvingAlasan     String?
  jumlah                             Int
  rataRata                           Int
  bobot                              Int
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime   @updatedAt
}

model Employee {
  id                   String           @id @default(cuid())
  employeeIdNumber     String           @unique
  nationalIdNumber     String?          @unique
  bpjsNumber           String?
  taxIdNumber          String?
  educatorIdNumber     String?
  fullName             String
  profilePhoto         String?
  placeOfBirth         String?
  dp3                  DP3[]
  dateOfBirth          DateTime?
  gender               Gender?
  maritalStatus        MaritalStatus?
  employmentStatus     EmploymentStatus @default(AKTIF)
  isBlocked            Boolean          @default(false)
  address              String?
  province             String?
  postalCode           String?
  secondaryAddress     String?
  secondaryProvince    String?
  secondaryPostalCode  String?
  email                String?
  phoneNumber          String?
  hobbies              String?
  height               Float?
  weight               Float?
  positionUnit         String?
  positionData         String?
  functionUnit         String?
  taskUnit             String?
  teachingUnit         String?
  subjectId            String?
  subject              Subject?              @relation(fields: [subjectId], references: [id])
  joinDate             DateTime?
  highestEducation     String?
  major                String?
  institutionName      String?
  graduationYear       Int?
  departmentId         String?
  department           Department?           @relation(fields: [departmentId], references: [id])
  positionId           String?
  position             Position?             @relation(fields: [positionId], references: [id])
  employmentStatusId   String?
  employmentStatusRef  EmploymentStatusMaster? @relation(fields: [employmentStatusId], references: [id])
  religionId           String?
  religion             Religion?             @relation(fields: [religionId], references: [id])
  bloodTypeId          String?
  bloodType            BloodType?            @relation(fields: [bloodTypeId], references: [id])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user               User?
  documents          EmployeeDocument[]
  history            EmployeeHistory[]
  educationHistories EducationHistory[]
  children           Child[]
  spouses            Spouse[]
  trainings          Training[]
  employmentDocuments EmploymentDocument[]
  certifications      Certification[]
  workUnits          WorkUnit[]
  healthData         HealthData[]
  socialOrganizations SocialOrganization[]
  importantDocuments ImportantDocument[]
  kesediaan          Kesediaan[]
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  type       String
  fileUrl    String
  uploadedAt DateTime @default(now())
}

model EmployeeHistory {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model AppConfiguration {
  id                 String   @id @default(cuid())
  appName            String   @default("SIMKA")
  appOwner           String?
  logoUrl            String?
  faviconUrl         String?
  address            String?
  phone              String?
  email              String?
  website            String?
  facebookUrl        String?
  instagramUrl       String?
  youtubeUrl         String?
  primaryColor       String   @default("#0f172a")
  secondaryColor     String   @default("#3b82f6")
  motto              String?
  vision             String?
  mission            String?
  copyright          String?
  footerText         String?
  activeYearId       String?
  activeYear         Year?    @relation(fields: [activeYearId], references: [id])
  activeSemester     Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
